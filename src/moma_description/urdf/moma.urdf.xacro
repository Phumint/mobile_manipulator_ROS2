<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro" name="moma_robot">

  <!-- ========================================== -->
  <!-- 0. DYNAMIC MOUNT BOX PARAMETERS            -->
  <!-- ========================================== -->
  <!-- These can be overridden in the launch file -->
  <xacro:arg name="box_length" default="0.81" />
  <xacro:arg name="box_width" default="0.45" />
  <xacro:arg name="box_height" default="0.555" />
  <xacro:arg name="mir_top_height" default="0.35" /> <!-- Approx height of MiR surface -->

  <!-- ========================================== -->
  <!-- 1. INCLUDE THE MIR BASE                    -->
  <!-- ========================================== -->
  <xacro:include filename="$(find mir_description)/urdf/mir.urdf.xacro" />

  <!-- ========================================== -->
  <!-- 2. THE MOUNTING BOX (THE "SURFACE")        -->
  <!-- ========================================== -->
  <joint name="mount_box_joint" type="fixed">
    <parent link="base_link" />
    <child link="mount_box_link" />
    <!-- Place the bottom of the box exactly on the MiR top surface -->
    <origin xyz="0 0 $(arg mir_top_height)" rpy="0 0 0" />
  </joint>

  <link name="mount_box_link">
    <visual>
      <!-- Visual origin is shifted up by half height so the base sits at Z=0 of the joint -->
      <origin xyz="0 0 ${$(arg box_height) / 2.0}" rpy="0 0 0" />
      <geometry>
        <box size="$(arg box_length) $(arg box_width) $(arg box_height)" />
      </geometry>
      <material name="dark_grey">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 ${$(arg box_height) / 2.0}" rpy="0 0 0" />
      <geometry>
        <box size="$(arg box_length) $(arg box_width) $(arg box_height)" />
      </geometry>
    </collision>
    <!-- Inertia is REQUIRED for Gazebo, otherwise the box falls through the floor -->
    <inertial>
      <origin xyz="0 0 ${$(arg box_height) / 2.0}" rpy="0 0 0" />
      <mass value="20.0" />
      <inertia ixx="0.5" ixy="0.0" ixz="0.0" iyy="0.5" iyz="0.0" izz="0.5" />
    </inertial>
  </link>

  <!-- Tell Gazebo to render the box grey -->
  <gazebo reference="mount_box_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <!-- ========================================== -->
  <!-- 3. INCLUDE THE UNIVERSAL ROBOT             -->
  <!-- ========================================== -->
  <xacro:include filename="$(find ur_description)/urdf/ur_macro.xacro" />

  <!-- 
    Instantiate the UR5e Arm on top of the box.
  -->
  <xacro:ur_robot
    name="ur10e"
    tf_prefix="ur_"
    parent="mount_box_link"
    joint_limits_parameters_file="$(find ur_description)/config/ur10e/joint_limits.yaml"
    kinematics_parameters_file="$(find ur_description)/config/ur10e/default_kinematics.yaml"
    physical_parameters_file="$(find ur_description)/config/ur10e/physical_parameters.yaml"
    visual_parameters_file="$(find ur_description)/config/ur10e/visual_parameters.yaml"
    use_fake_hardware="false"
    sim_ignition="true"
    initial_positions="${dict(shoulder_pan_joint=0.0, shoulder_lift_joint= -1.57 , elbow_joint=0.0, wrist_1_joint=0.0, wrist_2_joint=0.0, wrist_3_joint=1.57)}">
    
    <!-- 
      The Z offset here is EXACTLY the height of the box. 
      This guarantees the arm sits flush on the top surface.
    -->
    <origin xyz="${$(arg box_length)/2 - 0.087 - 0.013} 0.0 $(arg box_height)" rpy="0 0 0" />
  </xacro:ur_robot>

  <!-- Point the Ignition plugin at the existing ur_simulation_gz controllers yaml -->
  <gazebo>
    <plugin filename="ign_ros2_control-system"
            name="ign_ros2_control::IgnitionROS2ControlPlugin">
      <parameters>$(find ur_simulation_gz)/config/ur_controllers.yaml</parameters>
    </plugin>
  </gazebo>

</robot>